# =====================================================================
# ForgeShield OT — environment configuration (EXAMPLE)
# Copy to `.env` and fill in real values. NEVER commit a real .env.
# =====================================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the frontend
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Database (PostgreSQL) ----
POSTGRES_USER=forgeshield
POSTGRES_PASSWORD=forgeshield_dev_pw
POSTGRES_DB=forgeshield
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full SQLAlchemy URL is derived from the parts above by the backend, but can be overridden:
# DATABASE_URL=postgresql+psycopg://forgeshield:forgeshield_dev_pw@postgres:5432/forgeshield

# ---- Redis (cache, rate limiting, Celery broker) ----
REDIS_URL=redis://redis:6379/0

# ---- Auth: Supabase Cloud ----
# Create a free project at https://supabase.com and paste values from
# Project Settings -> API and Project Settings -> API -> JWT Settings.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
# Service role key — ONLY used by the backend seed script to provision demo users. Keep secret.
SUPABASE_SERVICE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY
# JWT secret from Project Settings -> API -> JWT Settings (used to verify access tokens, HS256).
SUPABASE_JWT_SECRET=YOUR-SUPABASE-JWT-SECRET
# Expected audience / issuer (defaults are correct for Supabase Cloud).
SUPABASE_JWT_AUD=authenticated

# If AUTH_DEV_BYPASS=true AND ENVIRONMENT=development, the backend will also accept
# locally-minted HS256 tokens signed with SUPABASE_JWT_SECRET. Useful for tests/CI.
# It is IGNORED unless ENVIRONMENT=development. Never enable in production.
AUTH_DEV_BYPASS=false

# Shared demo-user password used by the Supabase seed provisioner.
DEMO_USER_PASSWORD=Demo!ForgeShield123

# ---- AI provider (Cisco Foundation-Sec-8B-Reasoning via OpenAI-compatible endpoint) ----
# Options: local_foundation_sec | openai_compatible | mock
AI_PROVIDER=local_foundation_sec
# Base URL of your OpenAI-compatible inference server (vLLM / TGI / Ollama / etc.).
# Must include the OpenAI API prefix, e.g. http://host:8000/v1
AI_BASE_URL=http://localhost:8000/v1
AI_API_KEY=not-needed-for-local
AI_MODEL_NAME=Foundation-Sec-8B-Reasoning
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1400
AI_TIMEOUT_SECONDS=60
# Rate limit for the AI chat endpoint (slowapi syntax).
AI_RATE_LIMIT=20/minute
# Optional semantic retrieval (pgvector). Off by default; deterministic structured RAG is used.
AI_VECTOR_ENABLED=false

# ---- Reports ----
# PDF export uses WeasyPrint (heavy native deps). Markdown + HTML always available.
REPORTS_PDF_ENABLED=false

# ---- Seeding ----
# If true, the backend entrypoint loads demo data on startup (idempotent).
SEED_ON_START=true

# ---- Frontend (Vite) — these are read at build/runtime by the SPA ----
# NOTE: only VITE_-prefixed vars are exposed to the browser. Never put the service key here.
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
